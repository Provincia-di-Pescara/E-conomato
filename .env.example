# E-conomato — esempio di configurazione
# Copia questo file in `.env` e adatta i valori al tuo ambiente.
# Non committare MAI un `.env` con credenziali reali.

# ── Server ──────────────────────────────────────────────────────────────────
# Porta di ascolto dell'applicazione.
APP_PORT=8080

# Livello di log: debug, info, warn, error
LOG_LEVEL=info

# Override manuale della versione mostrata in UI/log. Se vuoto, viene usato il
# valore iniettato a build time via -ldflags "-X main.AppVersion=..."
# APP_VERSION=dev

# Base URL pubblico dell'app, usato per costruire i link assoluti nelle email
# transazionali (es. notifiche ordine). Vuoto = i link nelle email usano path
# relativi al dominio in cui l'app è esposta.
# APP_BASE_URL=https://e-conomato.example.com

# ── Sicurezza sessioni ──────────────────────────────────────────────────────
# Generabile con: openssl rand -hex 32
SESSION_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Flag Secure sui cookie di sessione (richiede HTTPS).
# Impostare a false SOLO dietro un reverse proxy che termina TLS (es. Traefik,
# Nginx) e parla in HTTP con l'app sulla rete interna.
SECURE_COOKIES=true

# Durata (ore) del cookie di login. Dopo questo tempo serve nuova autenticazione.
LOGIN_SESSION_TTL_HOURS=24

# ── LDAP / Active Directory ─────────────────────────────────────────────────
# Dev: LDAP_HOST=mock accetta qualunque credenziale e crea 3 utenti di test
# (mock.utente, mock.funzionario, mock.magazzino) tutti nel settore "MOCK".
# Prod: ldap:// porta 389 oppure ldaps:// porta 636 (TLS consigliato).
LDAP_HOST=mock
#LDAP_HOST=ldap://dc.example.com:389
#LDAP_HOST=ldaps://dc.example.com:636

# true = ignora errori di certificato (utile per CA interna / self-signed).
LDAP_TLS_SKIP_VERIFY=false

# Upgrade automatico da ldap:// a TLS via StartTLS. false = solo plain-text.
LDAP_STARTTLS=true

# Base DN del dominio AD.
LDAP_BASE_DN=dc=example,dc=com

# Template DN dell'utente. %s viene sostituito con lo username al login.
# Stile UPN (Active Directory moderno):
LDAP_USER_DN_TEMPLATE=%s@example.com
# Stile DN classico (OpenLDAP / legacy AD):
#LDAP_USER_DN_TEMPLATE=uid=%s,ou=Users,dc=example,dc=com

# Service account per le query di lookup dei gruppi.
# Necessario solo se l'utente autenticato non può cercare in directory.
# Lascia vuoto per riutilizzare la sessione dell'utente.
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# CN del gruppo AD richiesto per accedere (senza OU/DC).
# Vuoto = qualunque utente del dominio può accedere.
LDAP_REQUIRED_GROUP=

# Gruppo AD che assegna il ruolo "magazziniere".
# Vuoto = nessun utente verrà mappato come magazziniere via LDAP.
LDAP_MAGAZZINIERE_GROUP=

# Gruppo AD che assegna il ruolo "funzionario".
# Vuoto = nessun utente verrà mappato come funzionario via LDAP.
LDAP_FUNZIONARIO_GROUP=

# Gruppo AD che assegna il ruolo "economo" (Cassa Economale).
# L'Economo opera come Agente Contabile (artt. 93/233 D.Lgs. 267/2000) e
# accede alla dashboard /dashboard-economo per la gestione del Fondo Economale.
# Vuoto = nessun utente verrà mappato come economo via LDAP.
LDAP_ECONOMO_GROUP=

# ── Branding aziendale (opzionale) ──────────────────────────────────────────
# Mostra nome ente e logo accanto al logo E-conomato (sidebar + login).
# BRAND_LOGO accetta:
#   - URL esterno: https://www.example.com/logo.png
#   - Path locale: il file deve esistere in /data (es. brand-logo.png)
# Se vuoto, l'interfaccia rimane invariata.
#BRAND_NAME=Provincia di Pescara
#BRAND_LOGO=brand-logo.png

# ── Persistenza ─────────────────────────────────────────────────────────────
# DATA_DIR: path sull'host montato come /data dentro al container.
# Cambia questo valore per spostare DB e backup su un altro disco.
DATA_DIR=./data

# Path interno al container — non modificare se non strettamente necessario.
DB_PATH=/data/magazzino.db

# ── SMTP (opzionale) ────────────────────────────────────────────────────────
# Configura per abilitare le notifiche email transazionali ai cambi di stato
# dell'ordine. Lasciare vuoto per disabilitare.
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURITY=auto
# Modalità ammesse: auto | starttls | ssl | none
# - auto:     prova STARTTLS se il server lo supporta (default retro-compatibile)
# - starttls: richiede STARTTLS (consigliato per porta 587)
# - ssl:      TLS implicito (tipicamente porta 465)
# - none:     SMTP in chiaro (solo per reti interne fidate)
# SMTP_USER=noreply
# SMTP_PASSWORD='your_password'
# SMTP_FROM=noreply@example.com